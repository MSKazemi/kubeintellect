# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# .helmignore
# Common build directories
*.tgz
*.pack
*.tar.gz
*.zip
*.log
*.tmp
*.bak
*.swp

# Git and CI
.git/
.gitignore
.github/
.gitlab-ci.yml

# Node and Python
node_modules/
__pycache__/
venv/
.env
*.pyc

# IDE files
.idea/
.vscode/

# Local data
data/
datasets/
images/
tmp/
scratch/
