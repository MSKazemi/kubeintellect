# KubeIntellect — Local Development Environment
#
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# .env is gitignored. Never commit it.
#
# Sections marked [SECRET] must be kept private.
# Sections marked [CONFIG] are non-sensitive configuration.

# ─────────────────────────────────────────────
# LLM PROVIDER [CONFIG]
# ─────────────────────────────────────────────
# "azure"   — Azure OpenAI (default)
# "openai"  — OpenAI API directly (set OPENAI_API_KEY below)
# "litellm" — Local proxy (Ollama, vLLM, etc.) via LiteLLM (set LITELLM_* below)
LLM_PROVIDER=azure

# ─────────────────────────────────────────────
# AZURE OPENAI [SECRET + CONFIG]
# ─────────────────────────────────────────────
# Azure Portal → your OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# Model deployment names (Azure OpenAI Studio → Deployments)
AZURE_PRIMARY_LLM_DEPLOYMENT_NAME=gpt-4o
SUPERVISOR_AZURE_DEPLOYMENT_NAME=gpt-4o
# Optional: separate deployment for NLU classification (leave blank to use primary)
AZURE_NLU_LLM_DEPLOYMENT_NAME=

# Model parameters (optional overrides)
# AZURE_PRIMARY_LLM_TEMPERATURE=0.0
# AZURE_PRIMARY_LLM_MAX_TOKENS=4096
# SUPERVISOR_LLM_TEMPERATURE=0.0
# SUPERVISOR_LLM_MAX_TOKENS=1024

# ─────────────────────────────────────────────
# OPENAI DIRECT [SECRET + CONFIG]  (LLM_PROVIDER=openai)
# ─────────────────────────────────────────────
# OPENAI_API_KEY=
# SUPERVISOR_LLM_MODEL=gpt-4o
# PRIMARY_LLM_MODEL=gpt-4o

# ─────────────────────────────────────────────
# ANTHROPIC (Claude) [SECRET + CONFIG]  (LLM_PROVIDER=anthropic)
# ─────────────────────────────────────────────
# Install: uv add langchain-anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_WORKER_MODEL=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────
# GOOGLE GEMINI [SECRET + CONFIG]  (LLM_PROVIDER=google)
# ─────────────────────────────────────────────
# Install: uv add langchain-google-genai
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-1.5-pro
# GOOGLE_WORKER_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────
# AWS BEDROCK [CONFIG]  (LLM_PROVIDER=bedrock)
# ─────────────────────────────────────────────
# Install: uv add langchain-aws
# No API key needed — uses boto3 credential chain (env vars / ~/.aws / IAM role).
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_WORKER_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# ─────────────────────────────────────────────
# OLLAMA (local, direct) [CONFIG]  (LLM_PROVIDER=ollama)
# ─────────────────────────────────────────────
# No extra package needed. Run: ollama serve && ollama pull llama3
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─────────────────────────────────────────────
# LITELLM PROXY [CONFIG]  (LLM_PROVIDER=litellm)
# ─────────────────────────────────────────────
# Universal proxy — routes to any backend via an OpenAI-compatible API.
# LITELLM_BASE_URL=http://localhost:11434/v1
# LITELLM_MODEL=ollama/llama3

# ─────────────────────────────────────────────
# DEBUG [CONFIG]
# ─────────────────────────────────────────────
# Enables debug-level logging. Off by default.
# Set to true for local dev only — never in production.
DEBUG=false
# UNSAFE: Log full HTTP request bodies (user queries). Requires DEBUG=true.
# NEVER enable in production — request bodies contain sensitive user data.
UNSAFE_LOG_REQUEST_BODIES=false

# ─────────────────────────────────────────────
# LOGGING [CONFIG]
# ─────────────────────────────────────────────
# Minimum log severity: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
# Output format: "text" (human-readable) or "json" (structured, recommended in production)
LOG_FORMAT=text

# ─────────────────────────────────────────────
# CORS [CONFIG]
# ─────────────────────────────────────────────
# Comma-separated list of allowed origins. Restrict to your frontend in production.
# For Kind/local dev: http://localhost:3080,http://librechat.local
ALLOWED_ORIGINS=http://localhost:3080

# ─────────────────────────────────────────────
# POSTGRESQL [SECRET + CONFIG]
# ─────────────────────────────────────────────
# Override the default in-cluster hostname for local dev
POSTGRES_HOST=localhost
POSTGRES_DB=kubeintellectdb
POSTGRES_USER=kubeuser
POSTGRES_PASSWORD=

# ─────────────────────────────────────────────
# OBSERVABILITY QUERY ENDPOINTS [CONFIG]
# ─────────────────────────────────────────────
# Prometheus + Loki URLs used by MetricsAgent and LogsAgent to query the observability stack.
# Deploy the stack first: make install-observability-kind
# In-cluster defaults work out of the box after running that target.
PROMETHEUS_URL=http://prometheus-kube-prometheus-prometheus.kubeintellect.svc.cluster.local:9090
LOKI_URL=http://loki.kubeintellect.svc.cluster.local:3100

# LANGFUSE LLM OBSERVABILITY [SECRET + CONFIG] (optional, self-hosted)
# ─────────────────────────────────────────────
# Self-hosted Langfuse traces every LLM call: tokens, cost, latency, prompts.
# Deploy into Kind:  make kind-langfuse-deploy  (then open http://langfuse.local)
# Local docker-compose fallback: see langfuse-selfhosted/docker/docker-compose.yml
# After registering, create a project and copy the API keys below.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Local dev (Kind ingress or docker-compose):
LANGFUSE_HOST=http://langfuse.local
# In-cluster (pod → pod, no ingress hop):
# LANGFUSE_HOST=http://langfuse-web.kubeintellect.svc.cluster.local:3000

# ─────────────────────────────────────────────
# LANGSMITH TRACING [SECRET + CONFIG] (optional)
# ─────────────────────────────────────────────
# Set to true to enable tracing (requires API key + project)
KUBEINTELLECT_LANGSMITH_TRACING_ENABLED=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=kubeintellect-dev
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─────────────────────────────────────────────
# MEMORY [CONFIG]
# ─────────────────────────────────────────────
# Number of conversation turns to include in LLM context
SHORT_TERM_MEMORY_WINDOW=3

# ─────────────────────────────────────────────
# CONCURRENCY [CONFIG]
# ─────────────────────────────────────────────
# Maximum simultaneously in-flight workflow executions (prevents TPM exhaustion under load)
MAX_CONCURRENT_WORKFLOWS=20

# ─────────────────────────────────────────────
# RUNTIME TOOLS (PVC) [CONFIG]
# ─────────────────────────────────────────────
# For local dev: use a local directory instead of a PVC mount
RUNTIME_TOOLS_PVC_PATH=./local-runtime-tools
# TOOL_REGISTRY_FILE is removed — tool registry is now backed by PostgreSQL (tool_registry table)
TOOL_NAMING_PREFIX=gen_

# ─────────────────────────────────────────────
# GITHUB PR AUTOMATION [SECRET + CONFIG] (optional)
# ─────────────────────────────────────────────
# Auto-create GitHub PRs when AI-generated tools are registered, enabling code review before
# permanent inclusion in the static tool library.
# Requires a PAT with repo scope (fine-grained: Contents write + Pull requests write).
GITHUB_PR_ENABLED=false
# GITHUB_TOKEN=ghp_...         # PAT with repo scope
# GITHUB_REPO=myorg/kubeintellect
GITHUB_PR_TARGET_BRANCH=main
# Auto-create PR immediately after registration (vs using POST /tools/{tool_id}/create-pr manually)
GITHUB_PR_AUTO_CREATE=false
# Labels applied to each PR — must pre-exist in the repo
GITHUB_PR_LABELS=ai-generated,tool,needs-review

# ─────────────────────────────────────────────
# SSH TUNNEL [CONFIG] (optional)
# ─────────────────────────────────────────────
# Enable if Kubernetes API is only reachable via a bastion host
SSH_TUNNEL_ENABLED=false
# SSH_TUNNEL_SERVER_HOST=bastion.example.com
# SSH_TUNNEL_USER=ubuntu
# SSH_TUNNEL_KEY_PATH=~/.ssh/id_rsa
# SSH_TUNNEL_LOCAL_PORT=6443
# SSH_TUNNEL_K8S_API_HOST=127.0.0.1
# SSH_TUNNEL_K8S_API_PORT=6443

# ─────────────────────────────────────────────
# DEPLOYMENT SECRETS [SECRET]
# Required for Azure deployment and image pulls.
# Not used by local uvicorn dev — only by:
#   • scripts/ops/setup-secrets-infra.sh  (populates Azure Key Vault)
#   • Kind/Azure Helm values (image pull from GHCR)
# ─────────────────────────────────────────────

# API key LibreChat sends to the KubeIntellect endpoint
# (any strong random string — generate with: openssl rand -hex 32)
KUBEINTELLECT_API_KEY=

# GitHub Container Registry — PAT with read:packages scope only
# github.com → Settings → Developer settings → Personal access tokens
GHCR_USERNAME=<YOUR_GITHUB_USERNAME>
GHCR_PAT=

# ─────────────────────────────────────────────
# KIND LOCAL DEV USER [CONFIG]
# ─────────────────────────────────────────────
# LibreChat user created by 'make kind-dev-create-user' (called automatically by Kind deploy targets).
# Change these to whatever login you want for your local cluster.
DEV_USER_EMAIL=admin@kubeintellect.local
DEV_USER_PASSWORD=changeme

# ─────────────────────────────────────────────
# LANGFUSE API KEYS [SECRET] (optional — auto-generated if blank)
# ─────────────────────────────────────────────
# If left blank, generate-kind-secrets.sh creates random keys on first run and
# prints them here. Paste them in to lock keys across regenerations.
# Format: pk-lf-<hex>  /  sk-lf-<hex>
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
