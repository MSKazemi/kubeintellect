# KubeIntellect — environment configuration
#
# pip install quickstart (no repo clone needed):
#   pip install kubeintellect && pipx install kube-q
#   kubeintellect init          ← interactive wizard; writes ~/.kubeintellect/.env
#   kubeintellect serve         ← auto-detects database (postgres / docker / sqlite)
#   KUBE_Q_API_KEY=<key> kq --url http://localhost:8000
#
# Docker Compose quickstart (from repo):
#   cp .env.example .env
#   # Fill in your LLM API key and POSTGRES_PASSWORD, then:
#   docker compose up -d
#   KUBE_Q_API_KEY=<key> kq
#
# See docs/configuration.md for the full variable reference.

# ── LLM Provider — choose one: azure | openai ─────────────────────────────────
LLM_PROVIDER=azure

# ── OpenAI (used when LLM_PROVIDER=openai) ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_COORDINATOR_MODEL=gpt-4o
OPENAI_SUBAGENT_MODEL=gpt-4o-mini

# ── Azure OpenAI (used when LLM_PROVIDER=azure) ───────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_COORDINATOR_DEPLOYMENT=gpt-4o
AZURE_SUBAGENT_DEPLOYMENT=gpt-4o-mini

# ── Database ───────────────────────────────────────────────────────────────────
# kubeintellect serve auto-detects which backend to use:
#   1. Postgres running at POSTGRES_HOST:POSTGRES_PORT  → uses it
#   2. Docker available, no postgres                    → offers to start a container
#   3. No Docker                                        → falls back to SQLite (disk)
#
# Option A: Local postgres (default for Docker Compose / Kind)
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kubeintellect
POSTGRES_USER=kubeintellect
POSTGRES_POOL_MIN_CONN=1
POSTGRES_POOL_MAX_CONN=10

# Option B: External / managed database — overrides all POSTGRES_* vars above
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option C: SQLite (auto-set by kubeintellect serve; or force it manually)
# USE_SQLITE=true
# SQLITE_PATH=~/.kubeintellect/kubeintellect.db

# ── Kubernetes ─────────────────────────────────────────────────────────────────
KUBECONFIG_PATH=~/.kube/config
KUBECTL_TIMEOUT_SECONDS=30
KUBECTL_DESTRUCTIVE_TIMEOUT_SECONDS=300

# ── Observability — bring your own ────────────────────────────────────────────
# KubeIntellect queries these to answer metric/log questions about your cluster.
# Leave empty if you don't have them; kubectl-based queries still work without them.
#
# Local (Docker Compose --profile monitoring):
# PROMETHEUS_URL=http://localhost:9090
# LOKI_URL=http://localhost:3100
#
# Kind cluster (make monitoring-install):
# PROMETHEUS_URL=http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
# LOKI_URL=http://loki.monitoring.svc.cluster.local:3100
#
# Company / remote cluster — set to your existing endpoints:
PROMETHEUS_URL=
LOKI_URL=

# ── Langfuse — KubeIntellect's internal LLM tracing (optional) ───────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# ── Docker Compose profiles ────────────────────────────────────────────────────
# The docker-compose.yaml defines optional profiles to add observability on top
# of the core kubeintellect + postgres services.
#
# Run with monitoring (Prometheus / Grafana / Loki):
#   docker compose --profile monitoring up -d
#   Then uncomment and set:
# PROMETHEUS_URL=http://localhost:9090
# LOKI_URL=http://localhost:3100
#
# Run with Langfuse tracing:
#   docker compose --profile tracing up -d
#   Visit http://localhost:3001, create an account, go to Settings → API Keys.
#   Then set LANGFUSE_ENABLED=true and fill in the keys above.
#
# Run with both:
#   docker compose --profile monitoring --profile tracing up -d
#
# Langfuse docker-compose secrets (only needed when using --profile tracing):
# LANGFUSE_DB_PASSWORD=langfuse-local
# LANGFUSE_NEXTAUTH_SECRET=changeme-local-secret-32chars!!

# ── Container registry (for kind-build / ghcr pulls) ─────────────────────────
GHCR_USERNAME=your-github-username
GHCR_PAT=your-github-pat

# ── App ───────────────────────────────────────────────────────────────────────
# Auth: comma-separated API keys per role. Leave empty to disable auth (open access).
#   admin    — high + medium risk ops (delete, drain, apply, scale, exec…), HITL-gated
#   operator — medium risk only (create, apply, scale, exec…), HITL-gated; delete/drain blocked
#   readonly — read-only (get, describe, logs, top, events); all writes rejected
KUBEINTELLECT_ADMIN_KEYS=
KUBEINTELLECT_OPERATOR_KEYS=
KUBEINTELLECT_READONLY_KEYS=
LOG_LEVEL=INFO
LOG_FORMAT=text
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3080

# ── LangChain / LangSmith (optional cloud tracing) ───────────────────────────
LANGCHAIN_API_KEY=
